datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String      @id @default(uuid())
  total     Float
  createdAt DateTime    @default(now())

  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  name      String
  price     Float
  quantity  Int

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
}